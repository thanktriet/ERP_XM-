NODE_ENV=development
PORT=5000

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT (Supabase tự quản lý JWT, dùng key này để verify nếu cần)
JWT_SECRET=your-supabase-jwt-secret

# Frontend — một hoặc nhiều origin (phẩy), bắt buộc khớp Origin trình duyệt (vd GitHub Pages: https://thanktriet.github.io)
FRONTEND_URL=http://localhost:3000,https://thanktriet.github.io
